{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama-cloud/glm-5.1",
  "small_model": "ollama-cloud/qwen3.5:397b",
  "enabled_providers": ["ollama-cloud"],
  "provider": {
    "ollama-cloud": {
      "options": {
        "apiKey": "{env:OLLAMA_API_KEY}"
      }
    }
  },
  "agent": {
    "build": {
      "model": "ollama-cloud/glm-5.1"
    },
    "plan": {
      "model": "ollama-cloud/glm-5.1"
    },
    "explore": {
      "model": "ollama-cloud/kimi-k2.7-code"
    },
    "general": {
      "model": "ollama-cloud/qwen3.5:397b"
    },
    "vision": {
      "description": "Vision and image analysis using Qwen 3.5 Cloud (256K context, multimodal)",
      "mode": "subagent",
      "model": "ollama-cloud/qwen3.5:397b"
    },
    "code": {
      "description": "Programming-specialized agent using Kimi K2.7 Code (256K context)",
      "mode": "subagent",
      "model": "ollama-cloud/kimi-k2.7-code"
    },
    "large_project": {
      "description": "Large project agent using GLM 5.2 (1M context)",
      "mode": "subagent",
      "model": "ollama-cloud/glm-5.2"
    }
  }
}
