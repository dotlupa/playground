root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.md]
max_line_length = 72

[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2
max_line_length = 80

[{Dockerfile,dockerfile,*.dockerfile}]
indent_style = space
indent_size = 4
